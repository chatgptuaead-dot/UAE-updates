# ─────────────────────────────────────────────────────────────
#  UAE Gov Social Hub — Environment Configuration
# ─────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your keys.
#  The app runs in demo mode if keys are not set.
# ─────────────────────────────────────────────────────────────

PORT=3000

# ── X / Twitter API v2 ───────────────────────────────────────
# Get your Bearer Token from https://developer.twitter.com/
# Free Basic tier is sufficient (read-only access).
X_BEARER_TOKEN=

# ── Instagram Graph API ───────────────────────────────────────
# Requires a Facebook App with instagram_basic permission.
# 1. Create an app at https://developers.facebook.com/
# 2. Add Instagram Basic Display product
# 3. Generate a long-lived access token for each account
# 4. Find each account's numeric user ID via the Graph API
#    GET https://graph.instagram.com/me?fields=id&access_token=YOUR_TOKEN

IG_ACCESS_TOKEN=

# JSON map of Instagram username → numeric user ID
# Example: {"modgovae":"123456789","moiuae":"987654321", ...}
IG_USER_IDS=

# ── Cache ─────────────────────────────────────────────────────
# How long (ms) to cache API responses. Default: 5 minutes
CACHE_TTL=300000
